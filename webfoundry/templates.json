{"index.html":"<!DOCTYPE html><html><head>\n    <meta charset=\"utf-8\">\n    <title>webfoundry57</title>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, maximum-scale=1\">\n  </head>\n  <body class=\"flex flex-col [&amp;>div:first-child]:flex-1 min-h-screen\">\n    <script type=\"module\">\n      (async () => {\n        window.rootPrefix = /^\\/(files|preview)\\//.test(location.pathname) ? location.pathname.split('/').slice(0, 4).join('/') : '/';\n        if (rootPrefix === '/' || rootPrefix === '/collab.html') rootPrefix = '.';\n        let wforigin = new URL(location.href).searchParams.get('isolate') || location.origin;\n        if (/^(\\w+\\.)?(webfoundry.app|webfoundry\\d+\\.netlify\\.app|localhost)$/.test(wforigin)) throw new Error(`Bad isolation origin`);\n        if (new URL(location.href).searchParams.get('isolate') != null) {\n          await navigator.serviceWorker.register('/sw.js');\n          await navigator.serviceWorker.ready;\n          if (!navigator.serviceWorker.controller) return location.reload();\n          let parts = location.pathname.slice(1).split('/');\n          let tabId = parts[1];\n          window.wfThisProject = parts[2];\n          navigator.serviceWorker.addEventListener('message', async event => {\n            let { type, project, path } = event.data || {};\n            if (type !== 'fetch' || wfThisProject !== project) return;\n            let port = event.ports?.[0];\n            if (!port) return;\n            let handler = ev => {\n              let data = ev.data || {};\n              if (data.type !== 'fetch:res' || data.project !== project || data.path !== path) return;\n              removeEventListener('message', handler);\n              port.postMessage(data);\n            };\n            addEventListener('message', handler);\n            parent.postMessage({ type: 'fetch', project, path }, wforigin);\n          });\n          let register = () => navigator.serviceWorker.controller.postMessage({ type:'webfoundry-register-tab', tabId });\n          navigator.serviceWorker.addEventListener('controllerchange', register);\n          register();\n          if (!location.pathname.startsWith('/preview/')) {\n            let path = parts.slice(3).join('/');\n            if (path !== 'index.html') {\n              let handler = async ev => {\n                let data = ev.data || {};\n                if (data.type !== 'fetch:res' || data.project !== wfThisProject || data.path !== path) return;\n                removeEventListener('message', handler);\n                document.open();\n                document.write(await data.data.text());\n                document.close();\n              };\n              addEventListener('message', handler);\n              parent.postMessage({ type: 'fetch', project: wfThisProject, path }, wforigin);\n              return;\n            }\n          }\n          await new Promise(pres => setTimeout(pres, 100));\n        }\n        if (location.pathname.includes('/files/')) return;\n        let [, md, mapp] = await Promise.all([\n          import(`${rootPrefix}/webfoundry/head.js`),\n          import(`${rootPrefix}/webfoundry/dominant.js`),\n          import(`${rootPrefix}/webfoundry/app.js`),\n        ]);\n        document.body.prepend(md.default.el(mapp.default));\n        parent.postMessage({ path: `pages/${location.pathname.slice(1).split('/').slice(3).join('/')}`, type: 'ready', status: 200 }, wforigin);\n      })();\n    </script>\n  \n\n</body></html>\n","pages/index.html":"<!doctype html>\n<html>\n  <head>\n    <meta charset=\"utf-8\" />\n    <title>MEAT • Grindr clone</title>\n    <meta\n      name=\"viewport\"\n      content=\"width=device-width, initial-scale=1, maximum-scale=1\"\n    />\n    <script>\n      window.rootPrefix = /^\\/(files|preview)\\//.test(location.pathname)\n        ? location.pathname.split('/').slice(0, 4).join('/')\n        : '/';\n    </script>\n    <script type=\"module\" src=\"../webfoundry/ifdesigner.js\"></script>\n    <script src=\"../webfoundry/head.js\"></script>\n  </head>\n  <body\n    class=\"min-h-screen bg-slate-950 text-white flex flex-col\"\n    style=\"display: none\"\n  >\n    <div\n      class=\"min-h-screen bg-slate-950 text-white flex flex-col\"\n      wf-onattach=\"post('app.init')\"\n    >\n      <div\n        class=\"max-w-6xl mx-auto px-4 sm:px-6 py-8 gfont-Urbanist flex flex-col gap-8\"\n      >\n        <header class=\"flex flex-col gap-6 lg:flex-row lg:items-start\">\n          <div class=\"flex-1\">\n            <p class=\"text-xs uppercase tracking-[0.4em] text-amber-400\">\n              MEAT\n            </p>\n            <h1 class=\"text-4xl font-black mt-2 leading-tight\">\n              Grinder—looking for meat!\n            </h1>\n            <p class=\"text-sm text-slate-400 mt-1\">\n              Dial in your profile, filter the roster, and tap into the shared\n              Trystero room.\n            </p>\n          </div>\n          <div\n            class=\"w-full lg:w-auto bg-slate-900/60 rounded-2xl border border-slate-800 p-4 flex flex-col gap-2\"\n          >\n            <div class=\"text-sm text-slate-300\">\n              Room:\n              <span class=\"text-white font-semibold\"\n                >{{state.app.connection.roomId}}</span\n              >\n            </div>\n            <div class=\"flex items-center gap-3\">\n              <span\n                class=\"h-2 w-2 rounded-full\"\n                wf-class=\"{'bg-emerald-400': state.app.connection.status === 'connected', 'bg-amber-400': state.app.connection.status === 'connecting', 'bg-rose-500': state.app.connection.status === 'error'}\"\n              ></span>\n              <span\n                class=\"uppercase tracking-widest text-xs\"\n                wf-class=\"{'text-emerald-300': state.app.connection.status === 'connected', 'text-rose-300': state.app.connection.status === 'error', 'text-amber-300': state.app.connection.status === 'connecting'}\"\n                >{{state.app.connection.status}}</span\n              >\n            </div>\n            <div class=\"text-xs text-slate-500\">\n              {{state.app.connection.lastEvent}}\n            </div>\n            <button\n              class=\"text-xs font-semibold uppercase tracking-widest border border-amber-400/50 text-amber-300 rounded-full px-4 py-1 self-start hover:bg-amber-400/10\"\n              wf-onclick=\"post('app.refreshRoom')\"\n              value=\"\"\n            >\n              Reset link\n            </button>\n            <div\n              wf-if=\"state.app.connection.error\"\n              class=\"text-xs text-rose-300\"\n            >\n              {{state.app.connection.error}}\n            </div>\n          </div>\n        </header>\n\n        <div class=\"grid gap-8 lg:grid-cols-[320px,1fr]\">\n          <section class=\"space-y-6\">\n            <div\n              class=\"rounded-3xl overflow-hidden border border-slate-900 bg-gradient-to-b from-slate-900 to-slate-950 shadow-2xl\"\n            >\n              <div class=\"h-80 relative\">\n                <img\n                  class=\"absolute inset-0 object-cover object-center w-full h-full\"\n                  wf-src=\"state.app.me.photoUrl\"\n                />\n                <div\n                  class=\"absolute inset-0 bg-gradient-to-t from-slate-950 to-transparent\"\n                ></div>\n                <div\n                  class=\"absolute top-4 left-4 text-xs uppercase bg-black/50 px-3 py-1 rounded-full tracking-widest\"\n                >\n                  Live profile\n                </div>\n                <div class=\"absolute bottom-4 left-4 right-4\">\n                  <div class=\"flex items-center justify-between\">\n                    <div>\n                      <p class=\"text-2xl font-black\">\n                        {{state.app.me.displayName}}\n                      </p>\n                      <p class=\"text-sm text-slate-300\">\n                        {{state.app.me.age}} · {{state.app.me.tribe}} ·\n                        {{state.app.me.role}}\n                      </p>\n                    </div>\n                    <span\n                      class=\"text-xs bg-emerald-400 text-black px-3 py-1 rounded-full font-semibold\"\n                      >{{state.app.me.vibe}}</span\n                    >\n                  </div>\n                  <p class=\"text-sm text-slate-200 mt-3\">\n                    {{state.app.me.tagline}}\n                  </p>\n                  <div\n                    class=\"flex flex-wrap items-center gap-3 mt-4 text-xs text-slate-400\"\n                  >\n                    <span class=\"inline-flex items-center gap-1\"\n                      ><span class=\"h-2 w-2 rounded-full bg-lime-400\"></span\n                      >{{state.app.me.location}}</span\n                    >\n                    <span>•</span>\n                    <span>{{state.app.me.lookingFor}}</span>\n                    <button\n                      class=\"ml-auto px-3 py-1 rounded-full border border-slate-700 text-xs font-semibold\"\n                      wf-class=\"{'bg-emerald-400 text-black border-emerald-400': state.app.geolocation.status === 'ok'}\"\n                      wf-onclick=\"post('app.useGeolocation')\"\n                      value=\"\"\n                    >\n                      <span wf-if=\"state.app.me.location !== 'Somewhere'\"\n                        >Disable GPS</span\n                      >\n                      <span wf-if=\"state.app.me.location === 'Somewhere'\"\n                        >Use GPS</span\n                      >\n                    </button>\n                  </div>\n                  <p\n                    class=\"text-[0.65rem] uppercase tracking-widest text-slate-500 mt-1\"\n                    wf-if=\"state.app.geolocation.message\"\n                  >\n                    {{state.app.geolocation.message}}\n                  </p>\n                  <div class=\"flex flex-wrap gap-2 mt-4\">\n                    <span\n                      class=\"text-xs uppercase tracking-wider border border-white/20 rounded-full px-3 py-1\"\n                      wf-map=\"tag of state.app.me.hashtags\"\n                      >{{tag}}</span\n                    >\n                  </div>\n                </div>\n              </div>\n              <div class=\"p-4 bg-black/40 flex items-center gap-3\">\n                <div class=\"text-xs text-slate-400\">\n                  {{state.app.me.distance.toFixed ? state.app.me.distance.toFixed(1) : state.app.me.distance}} mi\n                  radius\n                </div>\n              </div>\n            </div>\n\n            <div\n              class=\"rounded-3xl border border-slate-900 bg-slate-900/60 p-5 space-y-4\"\n            >\n              <div class=\"flex items-center justify-between\">\n                <h2 class=\"text-lg font-semibold\">Profile edit</h2>\n                <span class=\"text-xs text-slate-400\">Broadcasts instantly</span>\n              </div>\n              <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                >Display name\n                <input\n                  wf-value=\"state.app.me.displayName\"\n                  wf-oninput=\"post('app.updateProfileField','displayName', _1.value)\"\n                  class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                  placeholder=\"Name\"\n                  value=\"\"\n                />\n              </label>\n              <div class=\"grid grid-cols-2 gap-4\">\n                <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                  >Age\n                  <input\n                    type=\"number\"\n                    min=\"18\"\n                    wf-value=\"state.app.me.age\"\n                    wf-oninput=\"post('app.updateProfileField','age', Number(_1.value))\"\n                    class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                    value=\"\"\n                  />\n                </label>\n                <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                  >Role\n                  <select\n                    wf-value=\"state.app.me.role\"\n                    wf-onchange=\"post('app.updateProfileField','role', _1.value)\"\n                    class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                    value=\"\"\n                  >\n                    <option value=\"Top\" selected=\"\">Top</option>\n                    <option value=\"Vers\">Vers</option>\n                    <option value=\"Bottom\">Bottom</option>\n                    <option value=\"Side\">Side</option>\n                  </select>\n                </label>\n              </div>\n              <div class=\"grid grid-cols-2 gap-4\">\n                <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                  >Tribe\n                  <select\n                    wf-value=\"state.app.me.tribe\"\n                    wf-onchange=\"post('app.updateProfileField','tribe', _1.value)\"\n                    class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                    value=\"\"\n                  >\n                    <option value=\"Discreet\" selected=\"\">Discreet</option>\n                    <option value=\"Bear\">Bear</option>\n                    <option value=\"Jock\">Jock</option>\n                    <option value=\"Geek\">Geek</option>\n                    <option value=\"Daddy\">Daddy</option>\n                  </select>\n                </label>\n                <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                  >Vibe\n                  <select\n                    wf-value=\"state.app.me.vibe\"\n                    wf-onchange=\"post('app.updateProfileField','vibe', _1.value)\"\n                    class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                    value=\"\"\n                  >\n                    <option value=\"Online\" selected=\"\">Online</option>\n                    <option value=\"Looking\">Looking</option>\n                    <option value=\"Hosting\">Hosting</option>\n                    <option value=\"Traveling\">Traveling</option>\n                    <option value=\"Stealth\">Stealth</option>\n                  </select>\n                </label>\n              </div>\n              <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                >Tagline\n                <input\n                  wf-value=\"state.app.me.tagline\"\n                  wf-oninput=\"post('app.updateProfileField','tagline', _1.value)\"\n                  class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                  placeholder=\"Say hi\"\n                  value=\"\"\n                />\n              </label>\n              <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                >Looking for\n                <input\n                  wf-value=\"state.app.me.lookingFor\"\n                  wf-oninput=\"post('app.updateProfileField','lookingFor', _1.value)\"\n                  class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                  placeholder=\"Hang, date, etc\"\n                  value=\"\"\n                />\n              </label>\n              <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                >Upload image\n                <input\n                  type=\"file\"\n                  id=\"meatPhotoPicker\"\n                  class=\"mt-1 w-full rounded-2xl bg-black/10 border border-dashed border-slate-800 px-4 py-3 text-slate-300 file:text-slate-200 file:bg-transparent file:border-0\"\n                  wf-onchange=\"post('app.pickPhoto','meatPhotoPicker')\"\n                  accept=\"image/*\"\n                  value=\"\"\n                />\n              </label>\n              <p class=\"text-xs text-slate-500\">\n                Stored locally in this browser and broadcast as a data URL.\n              </p>\n              <div\n                class=\"flex items-center justify-between gap-3 text-xs text-slate-400\"\n              >\n                <div>\n                  <p\n                    class=\"uppercase tracking-[0.3em] text-[0.6rem] text-slate-500\"\n                  >\n                    Current location\n                  </p>\n                  <p class=\"text-base text-white\">{{state.app.me.location}}</p>\n                </div>\n                <button\n                  class=\"px-3 py-2 rounded-full border border-slate-700\"\n                  wf-class=\"{'bg-emerald-400 text-black border-emerald-400': state.app.geolocation.status === 'ok'}\"\n                  wf-onclick=\"post('app.useGeolocation')\"\n                  value=\"\"\n                >\n                  <span wf-if=\"state.app.geolocation.status === 'ok'\"\n                    >GPS locked</span\n                  >\n                  <span wf-if=\"state.app.geolocation.status !== 'ok'\"\n                    >Use GPS</span\n                  >\n                </button>\n              </div>\n              <p\n                class=\"text-xs text-slate-500\"\n                wf-if=\"state.app.geolocation.message\"\n              >\n                {{state.app.geolocation.message}}\n              </p>\n              <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                >Distance radius (mi)\n                <input\n                  type=\"range\"\n                  min=\"0.2\"\n                  max=\"20\"\n                  step=\"0.2\"\n                  wf-value=\"state.app.me.distance\"\n                  wf-oninput=\"post('app.updateDistance', _1.value)\"\n                  class=\"mt-1 w-full\"\n                  value=\"10.2\"\n                />\n              </label>\n              <div class=\"text-xs text-slate-400\">Interests</div>\n              <div class=\"flex flex-wrap gap-2\">\n                <button\n                  wf-map=\"tag of state.app.vibeTags\"\n                  class=\"px-3 py-1 rounded-full border border-slate-800 text-xs uppercase tracking-widest\"\n                  wf-class=\"{'bg-amber-300 text-black border-amber-300': state.app.me.hashtags.includes(tag)}\"\n                  wf-onclick=\"post('app.toggleVibeTag', tag)\"\n                  value=\"\"\n                >\n                  {{tag}}\n                </button>\n              </div>\n            </div>\n\n            <div\n              class=\"rounded-3xl border border-slate-900 bg-black/40 p-5 space-y-4\"\n            >\n              <h2 class=\"text-lg font-semibold\">Filters</h2>\n              <div>\n                <p\n                  class=\"text-xs uppercase tracking-widest text-slate-400 mb-2\"\n                >\n                  Tribe\n                </p>\n                <div class=\"flex flex-wrap gap-2\">\n                  <button\n                    class=\"px-3 py-1 rounded-full border border-slate-800 text-xs\"\n                    wf-class=\"{'bg-white text-black border-white': state.app.filters.tribe === 'all'}\"\n                    wf-onclick=\"post('app.setFilter','tribe','all')\"\n                    value=\"\"\n                  >\n                    All\n                  </button>\n                  <button\n                    wf-map=\"tribe of state.app.trendingTribes\"\n                    class=\"px-3 py-1 rounded-full border border-slate-800 text-xs\"\n                    wf-class=\"{'bg-white text-black border-white': state.app.filters.tribe === tribe}\"\n                    wf-onclick=\"post('app.setFilter','tribe', tribe)\"\n                    value=\"\"\n                  >\n                    {{tribe}}\n                  </button>\n                </div>\n              </div>\n              <div>\n                <p\n                  class=\"text-xs uppercase tracking-widest text-slate-400 mb-2\"\n                >\n                  Vibe\n                </p>\n                <div class=\"flex flex-wrap gap-2\">\n                  <button\n                    class=\"px-3 py-1 rounded-full border border-slate-800 text-xs\"\n                    wf-class=\"{'bg-emerald-400 text-black border-emerald-400': state.app.filters.vibe === 'any'}\"\n                    wf-onclick=\"post('app.setFilter','vibe','any')\"\n                    value=\"\"\n                  >\n                    Any\n                  </button>\n                  <button\n                    class=\"px-3 py-1 rounded-full border border-slate-800 text-xs\"\n                    wf-class=\"{'bg-emerald-400 text-black border-emerald-400': state.app.filters.vibe === 'Online'}\"\n                    wf-onclick=\"post('app.setFilter','vibe','Online')\"\n                    value=\"\"\n                  >\n                    Online\n                  </button>\n                  <button\n                    class=\"px-3 py-1 rounded-full border border-slate-800 text-xs\"\n                    wf-class=\"{'bg-emerald-400 text-black border-emerald-400': state.app.filters.vibe === 'Hosting'}\"\n                    wf-onclick=\"post('app.setFilter','vibe','Hosting')\"\n                    value=\"\"\n                  >\n                    Hosting\n                  </button>\n                  <button\n                    class=\"px-3 py-1 rounded-full border border-slate-800 text-xs\"\n                    wf-class=\"{'bg-emerald-400 text-black border-emerald-400': state.app.filters.vibe === 'Looking'}\"\n                    wf-onclick=\"post('app.setFilter','vibe','Looking')\"\n                    value=\"\"\n                  >\n                    Looking\n                  </button>\n                </div>\n              </div>\n              <label\n                class=\"flex flex-col gap-2 text-xs uppercase tracking-widest text-slate-400\"\n                >Radius filter (mi)\n                <input\n                  type=\"range\"\n                  min=\"1\"\n                  max=\"30\"\n                  wf-value=\"state.app.filters.radius\"\n                  wf-oninput=\"post('app.setFilter','radius', Number(_1.value))\"\n                  value=\"16\"\n                />\n                <span class=\"text-sm text-white\"\n                  >{{state.app.filters.radius}} mi</span\n                >\n              </label>\n            </div>\n          </section>\n\n          <section class=\"space-y-4\">\n            <div class=\"flex items-center justify-between\">\n              <div>\n                <h2 class=\"text-2xl font-bold\">MEAT grid</h2>\n                <p class=\"text-sm text-slate-400\">\n                  {{state.app.visibleRoster.length}} guys showing ·\n                  {{state.app.connection.peers}} live\n                </p>\n              </div>\n              <div class=\"flex items-center gap-2\">\n                <input\n                  placeholder=\"Say something spicy\"\n                  wf-value=\"state.app.composer.text\"\n                  wf-oninput=\"post('app.updateComposer', _1.value)\"\n                  class=\"bg-black/40 border border-slate-800 rounded-full px-4 py-2 text-sm\"\n                  value=\"\"\n                />\n                <button\n                  class=\"px-3 py-2 rounded-full bg-amber-400 text-black text-xs uppercase tracking-widest\"\n                  wf-onclick=\"post('app.sendHello', state.app.visibleRoster[0]?.peerId || state.app.visibleRoster[0]?.userId)\"\n                  value=\"\"\n                  wf-class=\"{{!state.app.visibleRoster.length &amp;&amp; 'opacity-40 pointer-events-none'}}\"\n                >\n                  Tap first\n                </button>\n              </div>\n            </div>\n\n            <div\n              class=\"grid gap-4 sm:grid-cols-2 lg:grid-cols-3\"\n              wf-if=\"state.app.visibleRoster.length\"\n            >\n              <article\n                wf-map=\"guy of state.app.visibleRoster\"\n                class=\"group bg-slate-900/40 border border-slate-900 rounded-3xl overflow-hidden flex flex-col\"\n              >\n                <div class=\"relative h-48\">\n                  <img\n                    class=\"absolute inset-0 object-cover object-center w-full h-full\"\n                    wf-src=\"guy.photoUrl\"\n                  />\n                  <div\n                    class=\"absolute inset-0 bg-gradient-to-t from-black/80 to-transparent\"\n                  ></div>\n                  <div\n                    class=\"absolute top-3 left-3 text-xs bg-black/50 px-3 py-1 rounded-full\"\n                  >\n                    {{guy.vibe || 'Offline'}}\n                  </div>\n                  <div\n                    class=\"absolute bottom-3 left-3 right-3 flex items-end justify-between\"\n                  >\n                    <div>\n                      <p class=\"text-lg font-bold\">{{guy.displayName}}</p>\n                      <p class=\"text-xs text-slate-300\">\n                        {{guy.age}} · {{guy.tribe}}\n                      </p>\n                    </div>\n                    <span class=\"text-xs text-slate-300\"\n                      >{{guy.distance ? guy.distance.toFixed ? guy.distance.toFixed(1) : guy.distance : '—'}} mi</span\n                    >\n                  </div>\n                </div>\n                <div class=\"p-4 flex flex-col gap-3 flex-1\">\n                  <p class=\"text-sm text-slate-200\">{{guy.tagline}}</p>\n                  <div class=\"flex flex-wrap gap-2\">\n                    <span\n                      class=\"text-[0.65rem] uppercase tracking-widest border border-white/10 px-2 py-0.5 rounded-full\"\n                      wf-map=\"tag of guy.hashtags || []\"\n                      >{{tag}}</span\n                    >\n                  </div>\n                  <div\n                    class=\"mt-auto flex items-center justify-between text-xs text-slate-400\"\n                  >\n                    <span wf-if=\"guy.live\">Live</span>\n                    <span wf-if=\"!guy.live\" class=\"text-slate-600\">Idle</span>\n                    <button\n                      class=\"ml-auto px-3 py-1 rounded-full text-xs font-semibold\"\n                      wf-class=\"{'bg-emerald-400 text-black': guy.live, 'bg-slate-800 text-slate-400': !guy.live}\"\n                      wf-onclick=\"post('app.sendHello', guy.peerId || guy.userId)\"\n                      value=\"\"\n                    >\n                      Ping\n                    </button>\n                  </div>\n                </div>\n              </article>\n            </div>\n            <div\n              wf-if=\"!state.app.visibleRoster.length\"\n              class=\"text-center text-slate-500 border border-dashed border-slate-700 rounded-3xl p-10\"\n            >\n              No one fits the current filters. Widen the radius or tribe.\n            </div>\n          </section>\n        </div>\n\n        <div\n          wf-if=\"state.app.lastWave\"\n          class=\"fixed bottom-6 right-6 max-w-xs bg-black/80 border border-white/10 rounded-2xl px-4 py-3 text-sm\"\n          wf-class=\"{'text-emerald-300 border-emerald-400/40': state.app.lastWave.tone === 'inbound', 'text-amber-200 border-amber-400/40': state.app.lastWave.tone === 'sent', 'text-rose-200 border-rose-400/40': state.app.lastWave.tone === 'error'}\"\n        >\n          {{state.app.lastWave.text}}\n        </div>\n      </div>\n    </div>\n  </body>\n</html>\n"}