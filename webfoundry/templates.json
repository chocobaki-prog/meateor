{"index.html":"<!doctype html>\n<html>\n  <head>\n    <meta charset=\"utf-8\" />\n    <title>MEATEOR</title>\n    <meta\n      name=\"viewport\"\n      content=\"width=device-width, initial-scale=1, maximum-scale=1\"\n    />\n  </head>\n  <body class=\"flex flex-col [&amp;&gt;div:first-child]:flex-1 min-h-screen\">\n    <script type=\"module\">\n      (async () => {\n        window.rootPrefix = /^\\/(files|preview)\\//.test(location.pathname)\n          ? location.pathname.split('/').slice(0, 4).join('/')\n          : '/';\n        if (rootPrefix === '/' || rootPrefix === '/collab.html')\n          rootPrefix = '.';\n        let wforigin =\n          new URL(location.href).searchParams.get('isolate') || location.origin;\n        if (\n          /^(\\w+\\.)?(webfoundry.app|webfoundry\\d+\\.netlify\\.app|localhost)$/.test(\n            wforigin,\n          )\n        )\n          throw new Error(`Bad isolation origin`);\n        if (new URL(location.href).searchParams.get('isolate') != null) {\n          await navigator.serviceWorker.register('/sw.js');\n          await navigator.serviceWorker.ready;\n          if (!navigator.serviceWorker.controller) return location.reload();\n          let parts = location.pathname.slice(1).split('/');\n          let tabId = parts[1];\n          window.wfThisProject = parts[2];\n          navigator.serviceWorker.addEventListener('message', async event => {\n            let { type, project, path } = event.data || {};\n            if (type !== 'fetch' || wfThisProject !== project) return;\n            let port = event.ports?.[0];\n            if (!port) return;\n            let handler = ev => {\n              let data = ev.data || {};\n              if (\n                data.type !== 'fetch:res' ||\n                data.project !== project ||\n                data.path !== path\n              )\n                return;\n              removeEventListener('message', handler);\n              port.postMessage(data);\n            };\n            addEventListener('message', handler);\n            parent.postMessage({ type: 'fetch', project, path }, wforigin);\n          });\n          let register = () =>\n            navigator.serviceWorker.controller.postMessage({\n              type: 'webfoundry-register-tab',\n              tabId,\n            });\n          navigator.serviceWorker.addEventListener(\n            'controllerchange',\n            register,\n          );\n          register();\n          if (!location.pathname.startsWith('/preview/')) {\n            let path = parts.slice(3).join('/');\n            if (path !== 'index.html') {\n              let handler = async ev => {\n                let data = ev.data || {};\n                if (\n                  data.type !== 'fetch:res' ||\n                  data.project !== wfThisProject ||\n                  data.path !== path\n                )\n                  return;\n                removeEventListener('message', handler);\n                document.open();\n                document.write(await data.data.text());\n                document.close();\n              };\n              addEventListener('message', handler);\n              parent.postMessage(\n                { type: 'fetch', project: wfThisProject, path },\n                wforigin,\n              );\n              return;\n            }\n          }\n          await new Promise(pres => setTimeout(pres, 100));\n        }\n        if (location.pathname.includes('/files/')) return;\n        let [, md, mapp] = await Promise.all([\n          import(`${rootPrefix}/webfoundry/head.js`),\n          import(`${rootPrefix}/webfoundry/dominant.js`),\n          import(`${rootPrefix}/webfoundry/app.js`),\n        ]);\n        document.body.prepend(md.default.el(mapp.default));\n        parent.postMessage(\n          {\n            path: `pages/${location.pathname.slice(1).split('/').slice(3).join('/')}`,\n            type: 'ready',\n            status: 200,\n          },\n          wforigin,\n        );\n      })();\n    </script>\n  </body>\n</html>\n","pages/index.html":"<!doctype html>\n<html>\n  <head>\n    <meta charset=\"utf-8\" />\n    <title></title>\n    <meta\n      name=\"viewport\"\n      content=\"width=device-width, initial-scale=1, maximum-scale=1\"\n    />\n    <script>\n      window.rootPrefix = /^\\/(files|preview)\\//.test(location.pathname)\n        ? location.pathname.split('/').slice(0, 4).join('/')\n        : '/';\n    </script>\n    <script type=\"module\" src=\"../webfoundry/ifdesigner.js\"></script>\n    <script src=\"../webfoundry/head.js\"></script>\n  </head>\n  <body\n    class=\"min-h-screen bg-slate-950 text-white flex flex-col\"\n    style=\"display: none\"\n  >\n    <div\n      class=\"min-h-screen bg-slate-950 text-white flex flex-col\"\n      wf-onattach=\"post('app.init')\"\n    >\n      <div\n        class=\"mx-auto px-4 sm:px-6 py-8 gfont-Urbanist flex flex-col gap-8 xl:w-5xl w-full\"\n        wf-if=\"state.app.initialized\"\n      >\n        <header class=\"flex flex-col gap-6 lg:flex-row lg:items-start\">\n          <div class=\"flex-1\">\n            <p class=\"text-xs uppercase tracking-[0.4em] text-amber-400\">\n              MEATEOR\n            </p>\n            <h1 class=\"text-4xl font-black mt-2 leading-tight\">\n              Grinder—looking for meat!\n            </h1>\n            <p class=\"text-sm text-slate-400 mt-1\">\n              Dial in your profile, filter the roster, and tap into this shared\n              gay bar.\n            </p>\n          </div>\n        </header>\n\n        <div class=\"grid gap-8 lg:grid-cols-[320px,1fr]\">\n          <section class=\"space-y-6\">\n            <div\n              class=\"rounded-3xl overflow-hidden border border-slate-900 bg-gradient-to-b from-slate-900 to-slate-950 shadow-2xl\"\n            >\n              <div class=\"h-80 relative\">\n                <img\n                  class=\"absolute inset-0 object-cover object-center w-full h-full\"\n                  wf-src=\"state.app.me.photoUrl || 'media/placehoeder.png'\"\n                  src=\"../media/placehoeder.png\"\n                />\n                <div\n                  class=\"absolute inset-0 bg-gradient-to-t from-slate-950 to-transparent\"\n                ></div>\n                <div\n                  class=\"absolute top-4 left-4 text-xs uppercase bg-black/50 px-3 py-1 rounded-full tracking-widest\"\n                >\n                  Live profile\n                </div>\n                <div class=\"absolute bottom-4 left-4 right-4\">\n                  <div class=\"flex items-center justify-between\">\n                    <div>\n                      <p class=\"text-2xl font-black\">\n                        {{state.app.me.displayName}}\n                      </p>\n                      <p class=\"text-sm text-slate-300\">\n                        {{state.app.me.age}} · {{state.app.me.tribe}} ·\n                        {{state.app.me.role}}\n                      </p>\n                    </div>\n                  </div>\n                  <p class=\"text-sm text-slate-200 mt-3\">\n                    {{state.app.me.tagline}}\n                  </p>\n                  <div class=\"flex justify-between items-center\">\n                    <div\n                      class=\"flex flex-wrap items-center gap-3 mt-4 text-xs text-slate-400\"\n                    >\n                      <span>{{state.app.me.lookingFor}}</span>\n                    </div>\n                    <span\n                      class=\"text-xs bg-emerald-400 text-black px-3 py-1 rounded-full font-semibold\"\n                      >{{state.app.me.vibe}}</span\n                    >\n                  </div>\n                </div>\n              </div>\n            </div>\n\n            <div\n              class=\"rounded-3xl border border-slate-900 bg-slate-900/60 p-5 flex flex-col gap-4\"\n            >\n              <div class=\"flex items-center justify-between gap-4\">\n                <div>\n                  <h2 class=\"text-lg font-semibold\">Profile edit</h2>\n                  <span class=\"text-xs text-slate-400\"\n                    >Broadcasts instantly</span\n                  >\n                </div>\n                <button\n                  class=\"text-xs tracking-[0.3em] uppercase text-slate-400 flex items-center gap-2\"\n                  wf-onclick=\"post('app.toggleProfileCollapsed')\"\n                  value=\"\"\n                >\n                  <span wf-if=\"state.app.profileCollapsed\">Expand</span>\n                  <span wf-if=\"!state.app.profileCollapsed\">Collapse</span>\n                  <span\n                    class=\"inline-block transition-transform\"\n                    wf-class=\"{'rotate-180': !state.app.profileCollapsed}\"\n                    >^</span\n                  >\n                </button>\n              </div>\n              <p\n                wf-if=\"state.app.profileCollapsed\"\n                class=\"text-xs text-slate-500 border border-dashed border-slate-700 rounded-2xl px-4 py-3\"\n              >\n                Profile looks ready. Expand if you want to tweak anything.\n              </p>\n              <div\n                wf-if=\"!state.app.profileCollapsed\"\n                class=\"flex flex-col gap-4\"\n              >\n                <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                  >Display name\n                  <input\n                    wf-value=\"state.app.me.displayName\"\n                    class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                    placeholder=\"Name\"\n                    value=\"\"\n                  />\n                </label>\n                <div class=\"grid grid-cols-2 gap-4\">\n                  <label\n                    class=\"text-xs uppercase tracking-widest text-slate-400\"\n                    >Age\n                    <input\n                      wf-value=\"state.app.me.age\"\n                      class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                      value=\"\"\n                    />\n                  </label>\n                  <label\n                    class=\"text-xs uppercase tracking-widest text-slate-400\"\n                    >Role\n                    <select\n                      wf-value=\"state.app.me.role\"\n                      class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                      value=\"\"\n                    >\n                      <option value=\"Top\" selected=\"\">Top</option>\n                      <option value=\"Vers\">Vers</option>\n                      <option value=\"Bottom\">Bottom</option>\n                      <option value=\"Side\">Side</option>\n                    </select>\n                  </label>\n                </div>\n                <div class=\"grid grid-cols-2 gap-4\">\n                  <label\n                    class=\"text-xs uppercase tracking-widest text-slate-400\"\n                    >Tribe\n                    <select\n                      wf-value=\"state.app.me.tribe\"\n                      class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                      value=\"\"\n                    >\n                      <option value=\"Discreet\" selected=\"\">Discreet</option>\n                      <option value=\"Bear\">Bear</option>\n                      <option value=\"Jock\">Jock</option>\n                      <option value=\"Geek\">Geek</option>\n                      <option value=\"Daddy\">Daddy</option>\n                    </select>\n                  </label>\n                  <label\n                    class=\"text-xs uppercase tracking-widest text-slate-400\"\n                    >Vibe\n                    <select\n                      wf-value=\"state.app.me.vibe\"\n                      class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                      value=\"\"\n                    >\n                      <option value=\"Online\" selected=\"\">Online</option>\n                      <option value=\"Looking\">Looking</option>\n                      <option value=\"Hosting\">Hosting</option>\n                      <option value=\"Traveling\">Traveling</option>\n                      <option value=\"Stealth\">Stealth</option>\n                    </select>\n                  </label>\n                </div>\n                <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                  >Tagline\n                  <input\n                    wf-value=\"state.app.me.tagline\"\n                    class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                    placeholder=\"Say hi\"\n                    value=\"\"\n                  />\n                </label>\n                <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                  >Looking for\n                  <input\n                    wf-value=\"state.app.me.lookingFor\"\n                    class=\"mt-1 w-full rounded-2xl bg-black/40 border border-slate-800 px-4 py-3 text-white\"\n                    placeholder=\"Hang, date, etc\"\n                    value=\"\"\n                  />\n                </label>\n                <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                  >Upload image\n                  <input\n                    type=\"file\"\n                    id=\"meatPhotoPicker\"\n                    class=\"mt-1 w-full rounded-2xl bg-black/10 border border-dashed border-slate-800 px-4 py-3 text-slate-300 file:text-slate-200 file:bg-transparent file:border-0\"\n                    wf-onchange=\"post('app.pickPhoto','meatPhotoPicker')\"\n                    accept=\"image/*\"\n                    value=\"\"\n                  />\n                </label>\n\n                <div\n                  class=\"flex items-center justify-between gap-3 text-xs text-slate-400\"\n                >\n                  <div>\n                    <p\n                      class=\"uppercase tracking-[0.3em] text-[0.6rem] text-slate-500\"\n                    >\n                      Current location\n                    </p>\n                    <button\n                      class=\"ml-auto px-3 py-1 rounded-full border border-slate-700 text-xs font-semibold mt-2\"\n                      wf-class=\"{'bg-emerald-400 text-black border-emerald-400': state.app.geolocation.status === 'ok'}\"\n                      wf-onclick=\"state.app.radar.location ? state.app.radar.stop() : state.app.radar.start()\"\n                      value=\"\"\n                    >\n                      <span wf-if=\"state.app.radar.location\">Disable GPS</span>\n                      <span wf-if=\"!state.app.radar.location\">Use GPS</span>\n                    </button>\n                  </div>\n                </div>\n\n                <label class=\"text-xs uppercase tracking-widest text-slate-400\"\n                  >Distance radius (Km)\n                  <input\n                    type=\"range\"\n                    min=\"0.1\"\n                    max=\"200\"\n                    step=\"0.2\"\n                    wf-value=\"state.app.me.radius\"\n                    wf-oninput=\"post('app.updateProfileField','radius', _1.value)\"\n                    class=\"mt-1 w-full\"\n                    value=\"100.1\"\n                  />\n                </label>\n              </div>\n            </div>\n          </section>\n\n          <section class=\"space-y-4\">\n            <div class=\"flex items-center justify-between\">\n              <div>\n                <h2 class=\"text-2xl font-bold\">Meat in your area</h2>\n                <p class=\"text-sm text-slate-400\">\n                  {{state.app.roster.length}} guys showing ·\n                  {{state.app.love.peers.length}} live\n                </p>\n              </div>\n            </div>\n\n            <div\n              class=\"grid gap-4 sm:grid-cols-2 lg:grid-cols-3\"\n              wf-if=\"state.app.roster.length\"\n            >\n              <article\n                wf-map=\"guy of state.app.roster\"\n                class=\"group bg-slate-900/40 border border-slate-900 rounded-3xl overflow-hidden flex flex-col relative cursor-pointer transition ring-offset-2 ring-offset-slate-950\"\n                wf-onclick=\"post('app.openChat', guy.id)\"\n                wf-class=\"{{state.app.chat.unread[guy.id] &gt; 0 &amp;&amp; 'ring-2 ring-amber-400 border-amber-400'}} {{state.app.chat.openPeerId === guy.id &amp;&amp; 'ring-2 ring-emerald-400 border-emerald-400'}}\"\n              >\n                <span\n                  wf-if=\"state.app.chat.unread[guy.id] &gt; 0\"\n                  class=\"absolute top-3 right-3 text-[0.65rem] font-semibold bg-black/70 text-amber-300 px-2 py-1 rounded-full z-10 truncate max-w-16\"\n                  >{{state.app.chat.unread[guy.id]}}</span\n                >\n                <div class=\"relative h-48\">\n                  <div\n                    class=\"absolute inset-0 bg-gradient-to-t from-black/80 to-transparent overflow-hidden\"\n                  >\n                    <img\n                      class=\"absolute inset-0 object-cover object-center w-full h-full group-hover:scale-105\"\n                      wf-src=\"guy.photoUrl || 'media/placehoeder.png'\"\n                    />\n                  </div>\n                  <div\n                    class=\"absolute top-3 left-3 text-xs bg-black/50 px-3 py-1 rounded-full\"\n                  >\n                    {{guy.vibe || 'Offline'}}\n                  </div>\n                  <div\n                    class=\"absolute bottom-3 left-3 right-3 flex items-end justify-between\"\n                  >\n                    <div>\n                      <p class=\"text-lg font-bold\">{{guy.displayName}}</p>\n                      <p class=\"text-xs text-slate-300\">\n                        {{guy.age}} · {{guy.tribe}}\n                      </p>\n                    </div>\n                    <span class=\"text-xs text-slate-300 truncate\"\n                      >{{guy.location &amp;&amp; state.app.me.location ? state.app.radar.distance(guy.location).toFixed(1) + ' Km' : 'Somewhere'}}</span\n                    >\n                  </div>\n                </div>\n                <div class=\"p-4 flex flex-col gap-3 flex-1\">\n                  <p class=\"text-sm text-slate-200\">{{guy.tagline}}</p>\n                </div>\n              </article>\n            </div>\n            <div\n              wf-if=\"!state.app.roster.length\"\n              class=\"text-center text-slate-500 border border-dashed border-slate-700 rounded-3xl p-10\"\n            >\n              No one fits the current filters. Widen the radius or tribe.\n            </div>\n          </section>\n        </div>\n      </div>\n\n      <div\n        wf-if=\"state.app.chat.openPeerId\"\n        class=\"fixed inset-0 sm:inset-auto sm:right-6 sm:bottom-6 sm:w-[380px] sm:h-[560px] z-30\"\n      >\n        <div\n          class=\"flex flex-col bg-slate-950/95 border border-slate-800 backdrop-blur rounded-none sm:rounded-3xl w-full h-full shadow-2xl overflow-hidden\"\n          wf-if=\"state.app.activeChatPeer\"\n        >\n          <div\n            class=\"relative border-b border-slate-800 p-4 flex items-start gap-3\"\n          >\n            <img\n              class=\"w-16 h-16 rounded-2xl object-cover object-center border border-slate-800\"\n              wf-src=\"state.app.activeChatPeer.photoUrl || 'media/placehoeder.png'\"\n              src=\"../media/placehoeder.png\"\n            />\n            <div class=\"flex-1\">\n              <p class=\"text-lg font-semibold truncate\">\n                {{state.app.activeChatPeer.displayName}}\n              </p>\n              <p class=\"text-xs text-slate-400\">\n                {{state.app.activeChatPeer.age}} ·\n                {{state.app.activeChatPeer.tribe}} ·\n                {{state.app.activeChatPeer.role}}\n              </p>\n              <p class=\"text-xs text-slate-300 mt-2\">\n                {{state.app.activeChatPeer.tagline || 'No tagline yet'}}\n              </p>\n            </div>\n            <button\n              class=\"text-slate-400 text-xs uppercase tracking-[0.3em]\"\n              wf-onclick=\"post('app.closeChat')\"\n              value=\"\"\n            >\n              Close\n            </button>\n          </div>\n          <div class=\"flex-1 overflow-y-auto px-4 py-4 space-y-3\">\n            <div\n              wf-map=\"message of (state.app.chat.messages[state.app.chat.openPeerId] || [])\"\n              class=\"flex\"\n              wf-class=\"{'justify-end': message.direction === 'out'}\"\n            >\n              <div\n                class=\"px-4 py-2 rounded-2xl text-sm max-w-[80%]\"\n                wf-class=\"{'bg-emerald-500 text-black rounded-br-sm': message.direction === 'out', 'bg-slate-800 text-slate-100 rounded-bl-sm': message.direction !== 'out'}\"\n              >\n                <p class=\"whitespace-pre-wrap\">{{message.text}}</p>\n                <p class=\"text-[0.6rem] text-slate-300 mt-1\">\n                  {{new Date(message.timestamp || Date.now()).toLocaleTimeString()}}\n                </p>\n              </div>\n            </div>\n            <div\n              wf-if=\"!(state.app.chat.messages[state.app.chat.openPeerId] || []).length\"\n              class=\"text-center text-xs text-slate-500 py-10\"\n            >\n              No messages yet. Say hi!\n            </div>\n          </div>\n          <div class=\"border-t border-slate-800 p-4 flex gap-3\">\n            <textarea\n              class=\"flex-1 rounded-2xl bg-slate-900 border border-slate-800 px-4 py-3 text-sm text-white resize-none h-20\"\n              placeholder=\"Drop a line...\"\n              wf-value=\"state.app.chat.drafts[state.app.chat.openPeerId]\"\n              value=\"\"\n            ></textarea>\n            <button\n              class=\"px-4 py-3 rounded-2xl bg-emerald-400 text-black font-semibold text-sm\"\n              wf-onclick=\"post('app.sendChatMessage')\"\n              value=\"\"\n            >\n              Send\n            </button>\n          </div>\n        </div>\n        <div\n          wf-if=\"!state.app.activeChatPeer\"\n          class=\"flex flex-col bg-slate-950/95 border border-slate-800 rounded-none sm:rounded-3xl w-full h-full text-center items-center justify-center gap-4 shadow-2xl\"\n        >\n          <p class=\"text-sm text-slate-400 px-6\">\n            This player left the room. Pick someone else to keep chatting.\n          </p>\n          <button\n            class=\"px-4 py-2 rounded-full border border-slate-700 text-xs tracking-[0.3em]\"\n            wf-onclick=\"post('app.closeChat')\"\n            value=\"\"\n          >\n            Close\n          </button>\n        </div>\n      </div>\n    </div>\n  </body>\n</html>\n"}